# PostgreSQL (Vercel Postgres, Neon, RDS, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth.js / NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth (enables database sessions + Prisma adapter user records)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional: Resend for announcement emails (admin portal)
# RESEND_API_KEY=""
