# PostgreSQL (Vercel Postgres, Neon, RDS, etc.)
# Neon: "Pooled" for DATABASE_URL, "Direct" (no -pooler host) for DIRECT_URL — avoids migrate advisory-lock timeouts (P1002).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Optional: if builds still hit P1002 on Neon, set on Vercel too (ms). Default in npm build is 120000 via cross-env.
# PRISMA_MIGRATE_ADVISORY_LOCK_TIMEOUT=120000

# Auth.js / NextAuth — generate with: openssl rand -base64 32
# Set at least one on Vercel: AUTH_SECRET (v5) and/or NEXTAUTH_SECRET
AUTH_SECRET=""
NEXTAUTH_SECRET=""
# Must include scheme (https:// on production). Host-only values break Auth.js with ERR_INVALID_URL.
AUTH_URL=""
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth (enables database sessions + Prisma adapter user records)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional: Resend for announcement emails (admin portal)
# RESEND_API_KEY=""
# Verified sender domain in Resend (falls back to onboarding@resend.dev if key is set but this is empty)
# RESEND_FROM="Tournament Hub <notifications@yourdomain.com>"
